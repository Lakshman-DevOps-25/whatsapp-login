# Encryption key for storing tokens (32 chars)
ENCRYPTION_KEY=your_32_char_encryption_key_here!!

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
