# ─────────────────────────────────────────────────────────────────────────────
# DEVELOPER sets these ONCE — customers never see or touch these values.
# Get them from: https://developers.facebook.com → Your App → Settings → Basic
# ─────────────────────────────────────────────────────────────────────────────

# Your Meta App ID (found in Meta Developer Portal → Settings → Basic)
VITE_META_APP_ID=your_meta_app_id_here

# Your Embedded Signup Config ID (WhatsApp → Embedded Signup Builder)
VITE_META_CONFIG_ID=your_config_id_here
